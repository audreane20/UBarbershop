<!DOCTYPE html>
<html lang="{{ app_lang ?? 'en' }}">
  <head>
    <meta charset="UTF-8" />
    <title>UBarbershop – Admin Services</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="../public/css/admin.css" />
  </head>

  <body>
    <header class="site-header">
      <a class="logo logo-link" href="{{base_path}}" aria-label="UBarbershop Home">
        <img src="../public/images/logo.png" class="logo-img" />
        <span class="logo-text">UBarbershop</span>
      </a>

      <nav class="main-nav">
        <a href="{{base_path}}/calendar">{{ trans('nav.calendar') }}</a>
        <a href="{{base_path}}/admin">{{ trans('nav.addEmployee') }}</a>
        <a href="{{base_path}}/unavailable">{{ trans('nav.unavailable') }}</a>
        <a href="{{base_path}}/services">{{ trans('nav.services') }}</a>
        <a href="{{base_path}}">{{ trans('nav.exitAdmin') }}</a>
      </nav>

      <div class="header-actions">
        <div class="lang-switcher">
          <button data-lang="en">EN</button>
          <button data-lang="fr">FR</button>
        </div>
      </div>
    </header>

    <main class="page-content admin-page">
      <h1>{{ trans('servicesAdmin.title') }}</h1>

      <div class="admin-card">
        <p class="admin-subtitle">{{ trans('servicesAdmin.subtitle') }}</p>

        <div id="svc-msg" aria-live="polite"></div>
        <div id="svc-error" aria-live="polite"></div>

        <form id="svc-form" novalidate>
          <!-- Service ID is generated automatically. Hidden field is used for edit mode. -->
          <input id="svc-id" type="hidden" />

          <label for="svc-en">{{ trans('servicesAdmin.nameEn') }}</label>
          <input id="svc-en" type="text" required />

          <label for="svc-fr">{{ trans('servicesAdmin.nameFr') }}</label>
          <input id="svc-fr" type="text" required />

          <div class="field-grid two">
            <div class="field">
              <label for="svc-duration">
                {{ trans('servicesAdmin.duration') }}
              </label>
              <div class="input-wrap">
                <input id="svc-duration" type="number" min="5" step="5" required />
                <span class="suffix">min</span>
              </div>
            </div>

            <div class="field">
              <label for="svc-price">{{ trans('servicesAdmin.price') }}</label>
              <div class="input-wrap">
                <span class="prefix">$</span>
                <input
                  id="svc-price"
                  class="has-prefix"
                  type="number"
                  min="0"
                  step="1"
                  required
                />
              </div>
            </div>
          </div>

          <div class="field-grid two" style="margin-top: 10px;">
            <div class="field">
              <label for="svc-order">
                {{ trans('servicesAdmin.order') }}
              </label>
              <div class="input-wrap">
                <span class="prefix">#</span>
                <input
                  id="svc-order"
                  class="has-prefix"
                  type="number"
                  min="0"
                  step="1"
                  value="0"
                />
              </div>
            </div>

            <div class="field" style="display: flex; align-items: flex-end;">
              <label class="check-row">
                <input id="svc-active" type="checkbox" checked />
                <span>{{ trans('servicesAdmin.active') }}</span>
              </label>
            </div>
          </div>

          <div class="admin-actions">
            <button
              class="btn primary"
              type="submit"
            >
              {{ trans('servicesAdmin.add') }}
            </button>

            <button
              class="btn ghost"
              type="button"
              id="svc-clear"
            >
              {{ trans('servicesAdmin.clear') }}
            </button>
          </div>
        </form>

        <div class="employee-list-wrap" style="margin-top: 1.25rem;">
          <h2
            class="employee-list-title"
          >
            {{ trans('servicesAdmin.listTitle') }}
          </h2>
          <div id="svc-list"></div>
        </div>
      </div>
    </main>

    <footer class="site-footer">
      <p class="footer-bottom">
        &copy;
        <script>
          document.write(new Date().getFullYear());
        </script>
        UBarbershop
      </p>
    </footer>

    <script src="../public/js/lang.js"></script>
    <script type="module" src="../public/js/servicesAdmin.js"></script>

    <!-- Gate admin pages behind login -->
    <script type="module">
      import { auth } from "../public/js/firebase.js";
      import { onAuthStateChanged } from "https://www.gstatic.com/firebasejs/12.9.0/firebase-auth.js";

      onAuthStateChanged(auth, (user) => {
        if (!user) {
          window.location.href = "login.html";
        }
      });
    </script>

    <script src="../public/js/hamburgerMenu.js"></script>
    <script src="../public/js/activeNav.js"></script>
  </body>
</html>