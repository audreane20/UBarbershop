<!DOCTYPE html>
<html lang="{{ app_lang ?? 'en' }}">
<head>
    <meta charset="utf-8" />
    <title>UBarbershop – Contact</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link href="../public/css/contact.css" rel="stylesheet" />
    <link href="../public/css/header_footer.css" rel="stylesheet" />
</head>

<body>

    <!-- Header -->
    {% include 'utils/header.html.twig' %}

    <!-- Main -->
    <main class="contact-page">

        <h1>{{ trans('contact.title') }}</h1>

        <div class="contact-card">

            <h2>{{ trans('contact.helpTitle') }}</h2>

            <p>
				<strong>{{ trans('contact.phoneLabel') }}</strong>
				<a href="tel:+14504720174" class="contact-phone-link">
					(450) 472-0174
				</a>
			</p>

            <p>
			<strong>{{ trans('contact.addressLabel') }}</strong><br>
				UBarbershop<br><br>

				<a href="#" class="contact-address-link" onclick="openMaps(event)">
					771A Arthur-Sauvé,<br>
					Saint-Eustache, QC, Canada, J7R 4K3
				</a>
			</p>

            <div class="msg-title">
                <h3>{{ trans('contact.messageTitle') }}</h3>
            </div>

            <div class="contact-card-social-icons">
                <a
                    href="https://www.instagram.com/salonubarbershop/"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Instagram"
                >
                    <img src="../public/images/instagram.png" alt="Instagram" />
                </a>

                <a
                    href="https://www.facebook.com/p/U-barbershop-100067913270000/"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Facebook"
                >
                    <img src="../public/images/facebook.png" alt="Facebook" />
                </a>
            </div>

        </div>

    </main>

    <!-- Footer -->
    {% include 'utils/footer.html.twig' %}

    <!-- Scripts -->
    <script src="../public/js/contact.js" type="module"></script>
    <script src="../public/js/headerAuth.js" type="module"></script>
    <script src="../public/js/lang.js"></script>
    <script src="../public/js/hamburgerMenu.js"></script>
    <script src="../public/js/activeNav.js"></script>

	<script>
		function openMaps(event) {
			event.preventDefault();

			const address = "771A Arthur-Sauvé, Saint-Eustache, QC, Canada, J7R 4K3";
			const encoded = encodeURIComponent(address);
			const ua = navigator.userAgent || navigator.vendor || window.opera;

			if (/android/i.test(ua)) {
				window.location.href = `geo:0,0?q=${encoded}`;
			} else if (/iPad|iPhone|iPod/.test(ua) && !window.MSStream) {
				window.location.href = `http://maps.apple.com/?q=${encoded}`;
			} else {
				window.open(`https://www.google.com/maps/search/?api=1&query=${encoded}`, "_blank");
			}
		}
	</script>
</body>
</html>