<!DOCTYPE html>
<html lang="{{ app_lang ?? 'en' }}">
<head>
    <meta charset="utf-8" />
    <title>Register</title>

    <link href="../public/css/login.css" rel="stylesheet" />
    <link href="../public/css/header_footer.css" rel="stylesheet" />
</head>

<body>

    <!-- Header -->
    {% include 'utils/header.html.twig' %}

    <!-- Main -->
    <div class="page-container">

        <div class="box">

            <h2>{{ trans('auth.register.title') }}</h2>

            <form id="registerForm">

                <label>{{ trans('auth.name.label') }}</label>
                <input
                    id="regName"
                    type="text"
                    required
                    placeholder="Your name"
                    data-i18n-placeholder="auth.name.placeholder"
                />

                <label>{{ trans('auth.email.label') }}</label>
                <input
                    id="regEmail"
                    type="email"
                    required
                    placeholder="Email"
                    data-i18n-placeholder="auth.email.placeholder"
                />

                <label>{{ trans('auth.password.label') }}</label>
                <input
                    id="regPassword"
                    type="password"
                    required
                    placeholder="Password"
                    data-i18n-placeholder="auth.password.placeholder"
                />

                <label>{{ trans('auth.register.confirmLabel') }}</label>
                <input
                    id="regConfirmPassword"
                    type="password"
                    required
                    placeholder="Confirm Password"
                    data-i18n-placeholder="auth.register.confirmPlaceholder"
                />

                <button type="submit">
                    {{ trans('auth.register.button') }}
                </button>

                <p class="login-link">
                    <span>
                        {{ trans('auth.register.haveAccount') }}
                    </span>
                    <a href="{{base_path}}/login">
                        {{ trans('auth.register.goLogin') }}
                    </a>
                </p>

                <p class="error" id="regError"></p>

            </form>

        </div>

    </div>

    <!-- Footer -->
    {% include 'utils/footer.html.twig' %}

    <!-- Scripts -->
    <script src="../public/js/register.js" type="module"></script>
    <script src="../public/js/lang.js"></script>
    <script src="../public/js/headerAuth.js" type="module"></script>
    <script src="../public/js/hamburgerMenu.js"></script>
    <script src="../public/js/activeNav.js"></script>

</body>
</html>