<!DOCTYPE html>
<html lang="{{ app_lang ?? 'en' }}">
<head>
    <meta charset="utf-8" />
    <title>UBarbershop – About</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link href="../public/css/about.css" rel="stylesheet" />
    <link href="../public/css/header_footer.css" rel="stylesheet" />
</head>

<body>

    {% include 'utils/header.html.twig' %}
    
    <!-- Main -->
    <main class="about-page">

        <h1>{{ trans('about.title') }}</h1>

        <div class="about-card">

            <h2>{{ trans('about.subtitle') }}</h2>

            <p>{{ trans('about.p1') }}</p>

            <p>{{ trans('about.p2') }}</p>

            <p>{{ trans('about.p3') }}</p>

            <p class="thanks">{{ trans('about.thanks') }}</p>

        </div>

    </main>

    <!-- Footer -->
    {% include 'utils/footer.html.twig' %}

    <!-- Scripts -->
    <script src="../public/js/headerAuth.js" type="module"></script>
    <script src="../public/js/lang.js"></script>
    <script src="../public/js/hamburgerMenu.js"></script>
    <script src="../public/js/activeNav.js"></script>

</body>
</html>