<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Profile</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link href="../public/css/profile.css" rel="stylesheet" />
    <link href="../public/css/header_footer.css" rel="stylesheet" />
</head>

<body>

    <!-- Header -->
    <header class="site-header">

        <!-- LEFT SIDE -->
        <div class="header-left">
            <a class="logo" href="{{base_path}}">
                <img src="../public/images/logo.png" alt="UBarbershop Logo" class="logo-img" />
                <span class="logo-text">UBarbershop</span>
            </a>

            <a
                href="{{base_path}}/appointment"
                class="btn primary"
                id="header-appoint-button"
                data-i18n="appoint.submit"
            >
                Make an Appointment
            </a>
        </div>

        <!-- CENTER -->
        <nav class="main-nav">
            <a href="{{base_path}}" data-i18n="nav.home">Home</a>
            <a href="{{base_path}}/about" data-i18n="nav.about">About</a>
            <a href="{{base_path}}/contact" data-i18n="nav.contact">Contact</a>
        </nav>

        <!-- RIGHT SIDE -->
        <div class="header-actions">
            <a href="{{base_path}}/login" class="btn-login account-link" id="account-link">
                Login
            </a>

            <a
                href="{{base_path}}/calendar"
                class="btn-login admin-tab"
                id="admin-tab"
                data-i18n="nav.adminMode"
                style="display:none;"
            >
                Admin Mode
            </a>

            <div class="lang-switcher">
                <button data-lang="en">EN</button>
                <button data-lang="fr">FR</button>
            </div>
        </div>

    </header>

    <!-- Main -->
    <main class="page-container">

        <div class="box">

            <h2 data-i18n="auth.profile.title">My Profile</h2>

            <form id="profile-form">

                <label data-i18n="auth.name.label">Name</label>
                <input id="profile-name" type="text" />

                <label data-i18n="auth.email.label">Email</label>
                <input id="profile-email" type="email" disabled />

                <button
                    type="submit"
                    class="btn primary"
                    data-i18n="auth.profile.save"
                >
                    Save Changes
                </button>

                <p id="profile-msg"></p>

            </form>

            <button
                id="logout-btn"
                class="btn logout-btn"
                data-i18n="auth.profile.logout"
            >
                Logout
            </button>

        </div>

    </main>

    <!-- Footer -->
    {% include 'utils/footer.html.twig' %}

    <!-- Scripts -->
    <script src="../public/js/profile.js" type="module"></script>
    <script src="../public/js/lang.js"></script>
    <script src="../public/js/headerAuth.js" type="module"></script>
    <script src="../public/js/hamburgerMenu.js"></script>
    <script src="../public/js/activeNav.js"></script>

</body>
</html>