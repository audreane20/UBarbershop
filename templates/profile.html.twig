<!DOCTYPE html>
<html lang="{{ app_lang ?? 'en' }}">
<head>
    <meta charset="utf-8" />
    <title>Profile</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link href="../public/css/profile.css" rel="stylesheet" />
    <link href="../public/css/header_footer.css" rel="stylesheet" />
</head>

<body>

    <!-- Header -->
    <header class="site-header">

        <!-- LEFT SIDE -->
        <div class="header-left">
            <a class="logo" href="{{base_path}}">
                <img src="../public/images/logo.png" alt="UBarbershop Logo" class="logo-img" />
                <span class="logo-text">UBarbershop</span>
            </a>

            <a
                href="{{base_path}}/appointment"
                class="btn primary"
                id="header-appoint-button"
            >
                {{ trans('appoint.submit') }}
            </a>
        </div>

        <!-- CENTER -->
        <nav class="main-nav">
            <a href="{{base_path}}">{{ trans('nav.home') }}</a>
            <a href="{{base_path}}/about">{{ trans('nav.about') }}</a>
            <a href="{{base_path}}/contact">{{ trans('nav.contact') }}</a>
        </nav>

        <!-- RIGHT SIDE -->
        <div class="header-actions">
            <a href="{{base_path}}/login" class="btn-login account-link" id="account-link">
                Login
            </a>

            <a
                href="{{base_path}}/calendar"
                class="btn-login admin-tab"
                id="admin-tab"
                style="display:none;"
            >
                {{ trans('nav.adminMode') }}
            </a>

            <div class="lang-switcher">
                <button data-lang="en">EN</button>
                <button data-lang="fr">FR</button>
            </div>
        </div>

    </header>

    <!-- Main -->
    <main class="page-container">

        <div class="box">

            <h2>{{ trans('auth.profile.title') }}</h2>

            <form id="profile-form">

                <label>{{ trans('auth.name.label') }}</label>
                <input id="profile-name" type="text" />

                <label>{{ trans('auth.email.label') }}</label>
                <input id="profile-email" type="email" disabled />

                <button
                    type="submit"
                    class="btn primary"
                >
                    {{ trans('auth.profile.save') }}
                </button>

                <p id="profile-msg"></p>

            </form>

            <button
                id="logout-btn"
                class="btn logout-btn"
            >
                {{ trans('auth.profile.logout') }}
            </button>

        </div>

    </main>

    <!-- Footer -->
    {% include 'utils/footer.html.twig' %}

    <!-- Scripts -->
    <script src="../public/js/profile.js" type="module"></script>
    <script src="../public/js/lang.js"></script>
    <script src="../public/js/headerAuth.js" type="module"></script>
    <script src="../public/js/hamburgerMenu.js"></script>
    <script src="../public/js/activeNav.js"></script>

</body>
</html>