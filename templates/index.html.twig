<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>UBarbershop – Home</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link href="../public/css/header_footer.css" rel="stylesheet" />
    <link href="../public/css/home.css" rel="stylesheet" />
</head>

<body>

    <!-- Header -->
    {% include "utils/header.html.twig" %}

    <!-- Main -->
    <main class="home-main">

        <!-- HERO -->
        <section
            class="home-hero"
            style="--hero:url('../images/salon/fullSalon.png')"
        >
            <div class="home-hero-inner">

                <p class="home-pill" data-i18n="home.hero.pill">
                    Fresh cuts • Clean fades • Beard grooming
                </p>

                <h1 class="home-title" data-i18n="home.hero.title">
                    Look sharp. Feel confident.
                </h1>

                <p class="home-sub" data-i18n="home.hero.sub">
                    Book your appointment in seconds — professional barbers, clean shop, great results.
                </p>

                <div class="home-actions">
                    <a
                        href="appointment.html"
                        class="home-btn primary"
                        data-i18n="home.hero.book"
                    >
                        Book Appointment
                    </a>

                    <a
                        href="#home-gallery"
                        class="home-btn ghost"
                        data-i18n="home.hero.gallery"
                    >
                        View Gallery
                    </a>
                </div>

                <div class="home-hero-cards">

                    <article class="home-mini">
                        <img src="../public/images/salon/bookingNotification.png" alt="Booking notifications" />
                        <div>
                            <h3 data-i18n="home.addons.online.title">Online Booking</h3>
                            <p data-i18n="home.addons.online.desc">Fast scheduling + reminders.</p>
                        </div>
                    </article>

                    <article class="home-mini">
                        <img src="../public/images/salon/freeSnack.png" alt="Free snacks" />
                        <div>
                            <h3 data-i18n="home.addons.snacks.title">Free Snacks</h3>
                            <p data-i18n="home.addons.snacks.desc">Relax while you wait.</p>
                        </div>
                    </article>

                    <article class="home-mini">
                        <img src="../public/images/salon/products.png" alt="Products" />
                        <div>
                            <h3 data-i18n="home.addons.products.title">Premium Products</h3>
                            <p data-i18n="home.addons.products.desc">Hair & beard care available.</p>
                        </div>
                    </article>

                </div>

            </div>
        </section>

        <!-- SERVICES -->
        <section class="home-section" id="home-services">

            <div class="home-section-head">
                <h2 data-i18n="home.services.title">Services</h2>
                <p data-i18n="home.services.subtitle">
                    Pick your service — we'll handle the rest.
                </p>
            </div>

            <div class="home-service-grid">

                <a class="home-service-card" href="appointment.html?service=haircut">
                    <img src="../public/images/salon/haircut.png" alt="Haircut" />
                    <div class="home-service-body">
                        <h3 data-i18n="home.services.haircut.title">Haircut</h3>
                        <p data-i18n="home.services.haircut.desc">Clean cut, sharp finish.</p>
                    </div>
                </a>

                <a class="home-service-card" href="appointment.html?service=hair_beard">
                    <img src="../public/images/salon/haircut2.png" alt="Fade haircut" />
                    <div class="home-service-body">
                        <h3 data-i18n="home.services.fade.title">Haircut & Beard Trim</h3>
                        <p data-i18n="home.services.fade.desc">Double your style.</p>
                    </div>
                </a>

                <a class="home-service-card" href="appointment.html?service=beard">
                    <img src="../public/images/salon/haircut3.png" alt="Beard grooming" />
                    <div class="home-service-body">
                        <h3 data-i18n="home.services.beard.title">Beard Groom</h3>
                        <p data-i18n="home.services.beard.desc">Trim + lineup for a clean look.</p>
                    </div>
                </a>

                <a class="home-service-card" href="appointment.html?service=kids">
                    <img src="../public/images/salon/kidsCut.png" alt="Kids cut" />
                    <div class="home-service-body">
                        <h3 data-i18n="home.services.kids.title">Kids Cut</h3>
                        <p data-i18n="home.services.kids.desc">Quick, friendly, and fresh.</p>
                    </div>
                </a>

            </div>

        </section>

        <!-- VIBE -->
        <section class="home-vibe">

            <div class="home-vibe-inner">

                <div class="home-vibe-card">
                    <img src="../public/images/salon/salonChair.png" alt="Salon chair" />
                    <div>
                        <h3 data-i18n="home.vibe.clean.title">Comfortable & clean</h3>
                        <p data-i18n="home.vibe.clean.desc">Modern setup with a great vibe.</p>
                    </div>
                </div>

                <div class="home-vibe-card">
                    <img src="../public/images/salon/esthetic1.png" alt="Detail work" />
                    <div>
                        <h3 data-i18n="home.vibe.detail.title">Detail-focused</h3>
                        <p data-i18n="home.vibe.detail.desc">Edges, blends, and lines done right.</p>
                    </div>
                </div>

                <div class="home-vibe-card">
                    <img src="../public/images/salon/esthetic2.png" alt="Precision" />
                    <div>
                        <h3 data-i18n="home.vibe.precision.title">Precision every time</h3>
                        <p data-i18n="home.vibe.precision.desc">Consistency you can trust.</p>
                    </div>
                </div>

            </div>

        </section>

        <!-- GALLERY -->
        <section class="home-section" id="home-gallery">

            <div class="home-section-head">
                <h2 data-i18n="home.gallery.title">Gallery</h2>
                <p data-i18n="home.gallery.subtitle">
                    Recent cuts & shop atmosphere.
                </p>
            </div>

            <div class="home-gallery-grid">
                <img src="../public/images/salon/haircut4.png" alt="Haircut style 4" loading="lazy" />
                <img src="../public/images/salon/haircut2.png" alt="Fade style" loading="lazy" />
                <img src="../public/images/salon/haircut3.png" alt="Beard trim" loading="lazy" />
                <img src="../public/images/salon/haircut.png" alt="Haircut style 1" loading="lazy" />
                <img src="../public/images/salon/fullSalon.png" alt="Full salon view" loading="lazy" />
                <img src="../public/images/salon/salonChair.png" alt="Salon chair" loading="lazy" />
            </div>

            <div class="home-center">
                <a
                    href="appointment.html"
                    class="home-btn primary"
                    data-i18n="home.gallery.cta"
                >
                    Book Your Spot
                </a>
            </div>

        </section>

    </main>

    <!-- Footer -->
    {% include 'utils/footer.html.twig' %}

    <!-- Scripts -->
    <script src="../js/headerAuth.js" type="module"></script>
    <script src="../js/home.js"></script>
    <script src="../js/lang.js"></script>
    <script src="../js/hamburgerMenu.js"></script>
    <script src="../js/activeNav.js"></script>

</body>
</html>