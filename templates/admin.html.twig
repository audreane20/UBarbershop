<!DOCTYPE html>
<html lang="{{ app_lang ?? 'en' }}">
  <head>
    <meta charset="UTF-8" />
    <title>UBarbershop – Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="../public/css/admin.css" />
  </head>

  <body>
    <header class="site-header">
      <a class="logo logo-link" href="{{base_path}}" aria-label="UBarbershop Home">
        <img src="../public/images/logo.png" class="logo-img" />
        <span class="logo-text">UBarbershop</span>
      </a>

      <nav class="main-nav">
        <a href="{{base_path}}/calendar">{{ trans('nav.calendar') }}</a>
        <a href="{{base_path}}/admin">{{ trans('nav.addEmployee') }}</a>
        <a href="{{base_path}}/unavailable">{{ trans('nav.unavailable') }}</a>
        <a href="{{base_path}}/services">{{ trans('nav.services') }}</a>
        <a href="{{base_path}}">{{ trans('nav.exitAdmin') }}</a>
      </nav>

      <div class="header-actions">
        <div class="lang-switcher">
          <button data-lang="en">EN</button>
          <button data-lang="fr">FR</button>
        </div>
      </div>
    </header>

    <main class="page-content admin-page">
      <h1>{{ trans('admin.title') }}</h1>

      <div class="admin-card">
        <p class="admin-subtitle">{{ trans('admin.subtitle') }}</p>

        <div id="admin-msg" aria-live="polite"></div>
        <div id="admin-error" aria-live="polite"></div>

        <form id="employee-form" novalidate>
          <label for="emp-name">{{ trans('admin.name') }}</label>
          <input
            id="emp-name"
            type="text"
            data-i18n-placeholder="admin.namePlaceholder"
            required
          />

          <label>{{ trans('admin.workSchedule') }}</label>
          <div class="week-grid" id="week-grid"></div>

          <div class="admin-actions">
            <button
              class="btn primary"
              type="submit"
            >
              {{ trans('admin.addEmployee') }}
            </button>
          </div>
        </form>

        <div class="employee-list-wrap">
          <h2
            class="employee-list-title"
          >
            {{ trans('admin.currentEmployees') }}
          </h2>
          <div id="employee-list"></div>
        </div>
      </div>

      <!-- Edit Modal -->
      <div class="modal-overlay" id="edit-overlay" hidden></div>

      <div
        class="modal"
        id="edit-modal"
        hidden
        role="dialog"
        aria-modal="true"
        aria-labelledby="edit-title"
      >
        <div class="modal-header">
          <h2 id="edit-title">
            {{ trans('admin.editTitle') }}
          </h2>
          <button
            type="button"
            class="btn icon"
            id="edit-close"
            aria-label="Close"
          >
            ✕
          </button>
        </div>

        <form id="edit-form" class="modal-body" novalidate>
          <label for="edit-name">{{ trans('admin.name') }}</label>
          <input id="edit-name" type="text" required />

          <label>{{ trans('admin.workSchedule') }}</label>
          <div class="week-grid" id="edit-week-grid"></div>

          <div class="modal-actions">
            <button
              type="button"
              class="btn ghost"
              id="edit-cancel"
            >
              {{ trans('admin.cancel') }}
            </button>

            <button
              type="submit"
              class="btn primary"
            >
              {{ trans('admin.saveChanges') }}
            </button>
          </div>
        </form>
      </div>
      <!-- /Edit Modal -->
    </main>

    <footer class="site-footer">
      <p class="footer-bottom">
        &copy;
        <script>
          document.write(new Date().getFullYear());
        </script>
        UBarbershop
      </p>
    </footer>

    <!-- IMPORTANT: lang.js must load first -->
    <script src="../public/js/lang.js"></script>
    <script type="module" src="../public/js/admin.js"></script>

    <script src="../public/js/hamburgerMenu.js"></script>
    <script src="../public/js/activeNav.js"></script>
  </body>
</html>