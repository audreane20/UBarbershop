<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>UBarbershop – Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="../public/css/admin.css" />
  </head>

  <body>
    <header class="site-header">
      <a class="logo logo-link" href="{{base_path}}" aria-label="UBarbershop Home">
        <img src="../public/images/logo.png" class="logo-img" />
        <span class="logo-text">UBarbershop</span>
      </a>

      <nav class="main-nav">
        <a href="{{base_path}}/calendar" data-i18n="nav.calendar">
          Appointments Calendar
        </a>
        <a href="{{base_path}}/admin" data-i18n="nav.addEmployee">
          Add Employee
        </a>
        <a href="{{base_path}}/unavailable" data-i18n="nav.unavailable">
          Unavailable Days
        </a>
        <a href="{{base_path}}/services" data-i18n="nav.services">
          Services
        </a>
        <a href="{{base_path}}" data-i18n="nav.exitAdmin">
          Exit Admin Mode
        </a>
      </nav>

      <div class="header-actions">
        <div class="lang-switcher">
          <button data-lang="en">EN</button>
          <button data-lang="fr">FR</button>
        </div>
      </div>
    </header>

    <main class="page-content admin-page">
      <h1 data-i18n="admin.title">Admin</h1>

      <div class="admin-card">
        <p class="admin-subtitle" data-i18n="admin.subtitle">
          Add hairdressers and set their working days + hours.
        </p>

        <div id="admin-msg" aria-live="polite"></div>
        <div id="admin-error" aria-live="polite"></div>

        <form id="employee-form" novalidate>
          <label for="emp-name" data-i18n="admin.name">Name</label>
          <input
            id="emp-name"
            type="text"
            data-i18n-placeholder="admin.namePlaceholder"
            required
          />

          <label data-i18n="admin.workSchedule">Work schedule</label>
          <div class="week-grid" id="week-grid"></div>

          <div class="admin-actions">
            <button
              class="btn primary"
              type="submit"
              data-i18n="admin.addEmployee"
            >
              Add employee
            </button>
          </div>
        </form>

        <div class="employee-list-wrap">
          <h2
            class="employee-list-title"
            data-i18n="admin.currentEmployees"
          >
            Current employees
          </h2>
          <div id="employee-list"></div>
        </div>
      </div>

      <!-- Edit Modal -->
      <div class="modal-overlay" id="edit-overlay" hidden></div>

      <div
        class="modal"
        id="edit-modal"
        hidden
        role="dialog"
        aria-modal="true"
        aria-labelledby="edit-title"
      >
        <div class="modal-header">
          <h2 id="edit-title" data-i18n="admin.editTitle">
            Edit stylist
          </h2>
          <button
            type="button"
            class="btn icon"
            id="edit-close"
            aria-label="Close"
          >
            ✕
          </button>
        </div>

        <form id="edit-form" class="modal-body" novalidate>
          <label for="edit-name" data-i18n="admin.name">Name</label>
          <input id="edit-name" type="text" required />

          <label data-i18n="admin.workSchedule">Work schedule</label>
          <div class="week-grid" id="edit-week-grid"></div>

          <div class="modal-actions">
            <button
              type="button"
              class="btn ghost"
              id="edit-cancel"
              data-i18n="admin.cancel"
            >
              Cancel
            </button>

            <button
              type="submit"
              class="btn primary"
              data-i18n="admin.saveChanges"
            >
              Save changes
            </button>
          </div>
        </form>
      </div>
      <!-- /Edit Modal -->
    </main>

    <footer class="site-footer">
      <p class="footer-bottom">
        &copy;
        <script>
          document.write(new Date().getFullYear());
        </script>
        UBarbershop
      </p>
    </footer>

    <!-- IMPORTANT: lang.js must load first -->
    <script src="../public/js/lang.js"></script>
    <script type="module" src="../public/js/admin.js"></script>

    <script src="../public/js/hamburgerMenu.js"></script>
    <script src="../public/js/activeNav.js"></script>
  </body>
</html>