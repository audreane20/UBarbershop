<!DOCTYPE html>
<html lang="{{ app_lang ?? 'en' }}">
<head>
    <meta charset="utf-8" />
    <title>UBarbershop – Appointment</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link href="../public/css/appointment.css" rel="stylesheet" />
    <link href="../public/css/header_footer.css" rel="stylesheet" />
</head>

<body>

    <!-- Header -->
    {% include 'utils/header.html.twig' %}

    <!-- Login required modal -->
    <div class="login-required-overlay" id="login-required-overlay" hidden>
        <div
            class="login-required-modal"
            role="dialog"
            aria-modal="true"
            aria-labelledby="login-required-title"
        >
            <h2 id="login-required-title">
                {{ trans('appoint.loginRequiredTitle') }}
            </h2>

            <p>{{ trans('appoint.loginRequiredMsg') }}</p>

            <div class="login-required-actions">
                <a
                    href="{{base_path}}/login"
                    class="btn primary"
                    id="login-required-login"
                >
                    {{ trans('appoint.loginRequiredLogin') }}
                </a>

                <a
                    href="{{base_path}}/register"
                    class="btn ghost"
                    id="login-required-register"
                >
                    {{ trans('appoint.loginRequiredRegister') }}
                </a>

                <a
                    href="{{base_path}}"
                    class="btn ghost"
                >
                    {{ trans('appoint.loginRequiredBack') }}
                </a>
            </div>
        </div>
    </div>

    <!-- Cancel confirmation modal -->
    <div class="confirm-overlay" id="cancel-confirm-overlay" hidden>
        <div
            class="confirm-modal"
            role="dialog"
            aria-modal="true"
            aria-labelledby="cancel-confirm-title"
        >
            <h2 id="cancel-confirm-title">
                {{ trans('confirm.deleteAppointment') }}
            </h2>

            <div class="confirm-actions">
                <button
                    type="button"
                    class="btn primary"
                    id="cancel-confirm-yes"
                >
                    {{ trans('confirm.confirmAction') }}
                </button>

                <button
                    type="button"
                    class="btn ghost"
                    id="cancel-confirm-no"
                >
                    {{ trans('confirm.keepAction') }}
                </button>
            </div>
        </div>
    </div>

    <!-- Main -->
    <main class="page-content appointment-page">

        <h1>{{ trans('appoint.title') }}</h1>

        <div class="appoint-card">

            <p class="appoint-subtitle">{{ trans('appoint.subtitle') }}</p>

            <div id="appoint-error" class="form-error" aria-live="polite"></div>
            <div id="appoint-success" class="form-success" aria-live="polite"></div>

            <form id="appoint-form" class="appoint-form" novalidate>

                <!-- Service -->
                <label for="service">{{ trans('appoint.serviceLabel') }}</label>
                <select id="service" required>
                    <option value="">{{ trans('appoint.servicePlaceholder') }}</option>
                </select>

                <!-- Hairdresser -->
                <label>{{ trans('appoint.dresserLabel') }}</label>
                <div id="dresser-box" class="dresser-box">
                    <!-- JS injects checkboxes -->
                </div>

                <small class="hint">{{ trans('appoint.dresserHint') }}</small>

                <!-- Date -->
                <label>{{ trans('appoint.dateLabel') }}</label>
                <input id="date" type="hidden" required />

                <div
                    id="booking-calendar"
                    class="booking-calendar"
                    aria-label="Calendar"
                ></div>

                <!-- Time -->
                <div class="row">
                    <div class="col">
                        <label for="time">{{ trans('appoint.timeLabel') }}</label>

                        <select id="time" required>
                            <option value="">{{ trans('appoint.timePlaceholder') }}</option>
                        </select>

                        <small id="time-hint" class="hint"></small>
                    </div>
                </div>

                <!-- Name -->
                <label for="name">{{ trans('appoint.nameLabel') }}</label>
                <input
                    id="name"
                    type="text"
                    required
                    placeholder="{{ trans('appoint.namePlaceholder') }}"
                />

                <!-- Email + Phone -->
                <div class="row">

                    <div class="col">
                        <label for="email">{{ trans('appoint.emailLabel') }}</label>
                        <input
                            id="email"
                            type="email"
                            required
                            placeholder="{{ trans('appoint.emailPlaceholder') }}"
                        />
                    </div>

                    <div class="col">
                        <label>{{ trans('appoint.phoneLabel') }}</label>
                        <input
                            id="phone"
                            type="tel"
                            placeholder="{{ trans('appoint.phonePlaceholder') }}"
                        />
                    </div>

                </div>

                <!-- Notes -->
                <label for="notes">{{ trans('appoint.notesLabel') }}</label>

                <textarea
                    id="notes"
                    rows="3"
                    placeholder="{{ trans('appoint.notesPlaceholder') }}"
                ></textarea>

                <!-- Submit -->
                <button
                    type="submit"
                    class="btn primary"
                >
                    {{ trans('appoint.confirmBtn') }}
                </button>

            </form>

            <!-- Appointments list -->
            <div class="appoint-list-wrap">

                <h2 class="appoint-list-title">{{ trans('appoint.upcomingTitle') }}</h2>

                <div id="appoint-list" class="appoint-list"></div>

                <button
                    type="button"
                    id="clear-appoint"
                    class="btn ghost"
                >
                    {{ trans('appoint.pastBtn') }}
                </button>

            </div>

        </div>

    </main>

    <!-- Past appointments modal -->
    <div
        class="passed-appointments-overlay"
        id="passed-appointments-overlay"
        hidden
    >
        <div
            class="passed-appointments-modal"
            role="dialog"
            aria-modal="true"
            aria-labelledby="passed-appointments-title"
        >
            <div class="passed-appointments-header">
                <h2 id="passed-appointments-title">
                    {{ trans('appoint.pastTitle') }}
                </h2>

                <button
                    type="button"
                    id="passed-appointments-close"
                    class="btn ghost passed-close-btn"
                    aria-label="Close"
                >
                    ×
                </button>
            </div>

            <div
                id="passed-appointments-list"
                class="appoint-list passed-appointments-list"
            ></div>
        </div>
    </div>

    <!-- Footer -->
    {% include 'utils/footer.html.twig' %}

    <!-- Scripts -->
    <script src="../public/js/headerAuth.js" type="module"></script>
    <script src="../public/js/lang.js"></script>
    <script src="../public/js/appointment.js?v=slotlocks1" type="module"></script>
    <script src="../public/js/hamburgerMenu.js"></script>
    <script src="../public/js/activeNav.js"></script>

</body>
</html>