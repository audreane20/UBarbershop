<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>UBarbershop – Appointment</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link href="../public/css/appointment.css" rel="stylesheet" />
    <link href="../public/css/header_footer.css" rel="stylesheet" />
</head>

<body>

    <!-- Header -->
    {% include "utils/header.html.twig" %}

    <!-- Login required modal -->
    <div class="login-required-overlay" id="login-required-overlay" hidden>
        <div
            class="login-required-modal"
            role="dialog"
            aria-modal="true"
            aria-labelledby="login-required-title"
        >
            <h2 id="login-required-title" data-i18n="appoint.loginRequiredTitle">
                Login required
            </h2>

            <p data-i18n="appoint.loginRequiredMsg">
                Please log in to book an appointment.
            </p>

            <div class="login-required-actions">
                <a
                    href="{{base_path}}/login"
                    class="btn primary"
                    id="login-required-login"
                    data-i18n="appoint.loginRequiredLogin"
                >
                    Login
                </a>

                <a
                    href="{{base_path}}/register"
                    class="btn ghost"
                    id="login-required-register"
                    data-i18n="appoint.loginRequiredRegister"
                >
                    Register
                </a>

                <a
                    href="{{base_path}}"
                    class="btn ghost"
                    data-i18n="appoint.loginRequiredBack"
                >
                    Back to Home
                </a>
            </div>
        </div>
    </div>

    <!-- Cancel confirmation modal -->
    <div class="confirm-overlay" id="cancel-confirm-overlay" hidden>
        <div
            class="confirm-modal"
            role="dialog"
            aria-modal="true"
            aria-labelledby="cancel-confirm-title"
        >
            <h2 id="cancel-confirm-title" data-i18n="confirm.deleteAppointment">
                Are you sure?
            </h2>

            <div class="confirm-actions">
                <button
                    type="button"
                    class="btn primary"
                    id="cancel-confirm-yes"
                    data-i18n="confirm.confirmAction"
                >
                    Yes, cancel appointment
                </button>

                <button
                    type="button"
                    class="btn ghost"
                    id="cancel-confirm-no"
                    data-i18n="confirm.keepAction"
                >
                    Keep appointment
                </button>
            </div>
        </div>
    </div>

    <!-- Main -->
    <main class="page-content appointment-page">

        <h1 data-i18n="appoint.title">Schedule an Appointment</h1>

        <div class="appoint-card">

            <p class="appoint-subtitle" data-i18n="appoint.subtitle">
                Choose a service and time. We’ll confirm your appointment.
            </p>

            <div id="appoint-error" class="form-error" aria-live="polite"></div>
            <div id="appoint-success" class="form-success" aria-live="polite"></div>

            <form id="appoint-form" class="appoint-form" novalidate>

                <!-- Service -->
                <label for="service" data-i18n="appoint.serviceLabel">Service</label>
                <select id="service" required>
                    <option value="" data-i18n="appoint.servicePlaceholder">
                        Select a service
                    </option>
                </select>

                <!-- Hairdresser -->
                <label data-i18n="appoint.dresserLabel">Hairdresser</label>
                <div id="dresser-box" class="dresser-box">
                    <!-- JS injects checkboxes -->
                </div>

                <small class="hint" data-i18n="appoint.dresserHint">
                    "Any available" selects all hairdressers.
                </small>

                <!-- Date -->
                <label data-i18n="appoint.dateLabel">Date</label>
                <input id="date" type="hidden" required />

                <div
                    id="booking-calendar"
                    class="booking-calendar"
                    aria-label="Calendar"
                ></div>

                <!-- Time -->
                <div class="row">
                    <div class="col">
                        <label for="time" data-i18n="appoint.timeLabel">Time</label>

                        <select id="time" required>
                            <option value="" data-i18n="appoint.timePlaceholder">
                                Select a time
                            </option>
                        </select>

                        <small id="time-hint" class="hint"></small>
                    </div>
                </div>

                <!-- Name -->
                <label for="name" data-i18n="appoint.nameLabel">Full Name</label>
                <input
                    id="name"
                    type="text"
                    required
                    placeholder="Your name"
                    data-i18n-placeholder="appoint.namePlaceholder"
                />

                <!-- Email + Phone -->
                <div class="row">

                    <div class="col">
                        <label for="email" data-i18n="appoint.emailLabel">Email</label>
                        <input
                            id="email"
                            type="email"
                            required
                            placeholder="you@example.com"
                            data-i18n-placeholder="appoint.emailPlaceholder"
                        />
                    </div>

                    <div class="col">
                        <label for="phone" data-i18n="appoint.phoneLabel">
                            Phone (optional)
                        </label>
                        <input
                            id="phone"
                            type="tel"
                            placeholder="(450) 000-0000"
                            data-i18n-placeholder="appoint.phonePlaceholder"
                        />
                    </div>

                </div>

                <!-- Notes -->
                <label for="notes" data-i18n="appoint.notesLabel">
                    Notes (optional)
                </label>

                <textarea
                    id="notes"
                    rows="3"
                    placeholder="Anything we should know?"
                    data-i18n-placeholder="appoint.notesPlaceholder"
                ></textarea>

                <!-- Submit -->
                <button
                    type="submit"
                    class="btn primary"
                    data-i18n="appoint.confirmBtn"
                >
                    Confirm Appointment
                </button>

            </form>

            <!-- Appointments list -->
            <div class="appoint-list-wrap">

                <h2 class="appoint-list-title" data-i18n="appoint.upcomingTitle">
                    Your upcoming appointments
                </h2>

                <div id="appoint-list" class="appoint-list"></div>

                <button
                    type="button"
                    id="clear-appoint"
                    class="btn ghost"
                    data-i18n="appoint.pastBtn"
                >
                    Passed appointments
                </button>

            </div>

        </div>

    </main>

    <!-- Past appointments modal -->
    <div
        class="passed-appointments-overlay"
        id="passed-appointments-overlay"
        hidden
    >
        <div
            class="passed-appointments-modal"
            role="dialog"
            aria-modal="true"
            aria-labelledby="passed-appointments-title"
        >
            <div class="passed-appointments-header">
                <h2 id="passed-appointments-title" data-i18n="appoint.pastTitle">
                    Past appointments
                </h2>

                <button
                    type="button"
                    id="passed-appointments-close"
                    class="btn ghost passed-close-btn"
                    aria-label="Close"
                >
                    ×
                </button>
            </div>

            <div
                id="passed-appointments-list"
                class="appoint-list passed-appointments-list"
            ></div>
        </div>
    </div>

    <!-- Footer -->
    {% include 'utils/footer.html.twig' %}

    <!-- Scripts -->
    <script src="../js/headerAuth.js" type="module"></script>
    <script src="../js/lang.js"></script>
    <script src="../js/appointment.js?v=slotlocks1" type="module"></script>
    <script src="../js/hamburgerMenu.js"></script>
    <script src="../js/activeNav.js"></script>

</body>
</html>