<!DOCTYPE html>
<html lang="{{ app_lang ?? 'en' }}">
<head>
    <meta charset="utf-8" />
    <title>UBarbershop – Login</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="{{base_path}}/css/header_footer.css" rel="stylesheet" />
    <link href="{{base_path}}/css/login.css" rel="stylesheet" />
</head>
<body>

    {% include 'utils/header.html.twig' %}

    <!-- Main -->
    <div class="page-container">
        <div class="box">
            <h2>{{ trans('auth.login.title') }}</h2>

            <form id="login-form" novalidate>

                <label for="email">{{ trans('auth.email.label') }}</label>
                <input
                    id="email"
                    type="email"
                    required
                    placeholder="Email"
                    data-i18n-placeholder="auth.email.placeholder"
                />

                <label for="password">{{ trans('auth.password.label') }}</label>
                <input
                    id="password"
                    type="password"
                    required
                    placeholder="Password"
                    data-i18n-placeholder="auth.password.placeholder"
                />

                <button type="submit" class="btn-primary">
                    {{ trans('auth.login.button') }}
                </button>

                <div class="auth-divider">
                    <span>{{ trans('auth.or') }}</span>
                </div>

                <button type="button" id="google-login" class="oauth-pill">
                    <span class="oauth-icon-wrap" aria-hidden="true">
                        <img src="../public/images/google_inv.png" alt="" class="oauth-icon" />
                    </span>
                    <span class="oauth-text">
                        {{ trans('auth.oauth.google') }}
                    </span>
                </button>

                <button type="button" id="facebook-login" class="oauth-pill oauth-facebook">
                    <span class="oauth-icon-wrap" aria-hidden="true">
                        <img src="../public/images/facebook.png" alt="" class="oauth-icon" />
                    </span>
                    <span class="oauth-text">
                        {{ trans('auth.oauth.facebook') }}
                    </span>
                </button>

                <p class="login-link">
                    <a href="#" id="forgot-password">
                        {{ trans('auth.login.forgot') }}
                    </a>
                </p>

                <p class="register-link">
                    <span>{{ trans('auth.login.noAccount') }}</span>
                    <a href="{{base_path}}/register">{{ trans('auth.login.registerLink') }}</a>
                </p>

                <p class="error" id="error"></p>

            </form>
        </div>
    </div>
    
    <!-- Footer -->
    {% include 'utils/footer.html.twig' %}
    
    <!-- Scripts -->
    <script src="../public/js/lang.js"></script>
    <script src="../public/js/login.js" type="module"></script>
    <script src="../public/js/headerAuth.js" type="module"></script>
    <script src="../public/js/hamburgerMenu.js"></script>
    <script src="../public/js/activeNav.js"></script>

</body>
</html>